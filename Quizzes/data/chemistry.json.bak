    "question": "The flame used by welders in cotton metals is",
    "options": [
      "butane gas flame",
      "acetylene flame",
      "kerosene flame",
      "oxy-acetylene flame",
      "oxygen flame"
    ],
    "answer": 3,
    "exam": [

  {
    "id": "CHEM-JAMB-0018",
    "question": "In the reaction Fe + Cu²⁺ → Fe²⁺ + Cu, iron displaces copper ions to form copper. This is due to the fact that",
    "options": [
      "iron is in the metallic form while the copper is in the ionic form",
      "the atomic weight of copper is greater than that of iron",
      "copper metal has more electrons than iron metal",
      "iron is an inert metal",
      "iron is higher in the electrochemical series than copper"
    ],
    "answer": 4,
    "exam": [
      "JAMB"
    ],
    "level": "easy",
    "topic": "Acids, Bases & Salts",
    "marks": 1,
    "explanation": "Displacement reactions occur when a more reactive metal displaces a less reactive metal from its salt solution. The reactivity series (electrochemical series) ranks metals by their tendency to lose electrons. Iron is above copper in the electrochemical series, meaning it is more easily oxidized and has a greater reducing power than copper. Therefore, iron donates electrons to Cu²⁺ ions, reducing them to copper metal while iron itself oxidizes to Fe²⁺.",
    "hint": "More reactive metals displace less reactive ones.",
    "timeLimit": 30,
    "year": 1983,
    "tags": [
      "chemistry",
      "electrochemical series",
      "displacement",
      "jamb"
    ],
    "requiresCalculator": false,
    "calculatorType": "none",
    "formula": "",
    "constants": {},
    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  },

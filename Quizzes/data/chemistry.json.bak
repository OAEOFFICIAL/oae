  {
    "id": "CHEM-JAMB-0034",
    "question": "Which of the following separation processes is most likely to yield high quality ethanol (>95%) from palm wine?",
    "options": [
      "Fractional distillation without a dehydrant",
      "Simple distillation without a dehydrant",
      "Fractional distillation with a dehydrant",
      "Column chromatography",
      "Evaporation"
    ],
    "answer": 2,
    "exam": [
      "JAMB"
    ],
    "level": "medium",
    "topic": "Practical Chemistry: Separation Techniques",
    "marks": 2,
    "explanation": "Ethanol and water form an azeotrope at approximately 95.6% ethanol. Simple or fractional distillation alone cannot exceed this concentration. To obtain high-quality ethanol (>95%), a dehydrating agent (such as quicklime, molecular sieves, or azeotropic distillation with benzene) is used to remove the remaining water. Fractional distillation with a dehydrant breaks the azeotrope.",
    "hint": "Ethanol-water azeotrope limits distillation without a dehydrant.",
    "timeLimit": 45,
    "year": 1983,
    "tags": [

    "lastUpdated": "2026-04-05"
  },
  {
    "id": "CHEM-JAMB-0050",
    "question": "30 cm³ of 0.1 M Al(NO3)3 solution is reacted with 100 cm³ of 0.15 M NaOH solution. Which is in excess and by how much?",
    "options": [
      "NaOH solution, by 70 cm³",
      "NaOH solution, by 60 cm³",
      "NaOH solution by 40 cm³",
      "Al(NO3)3 solution by 20 cm³",
      "Al(NO3)3 solution by 10 cm³"
    ],
    "answer": 2,
    "exam": [
      "JAMB"
    ],
    "level": "hard",
    "topic": "Acids, Bases & Salts",
    "marks": 3,
    "explanation": "Reaction: Al(NO3)3 + 3NaOH → Al(OH)3 + 3NaNO3. Mole ratio Al(NO3)3 : NaOH = 1:3. Moles Al(NO3)3 = (0.1 mol/dm³) × (30/1000) dm³ = 0.003 mol. Moles NaOH = (0.15 mol/dm³) × (100/1000) dm³ = 0.015 mol. Moles NaOH required for 0.003 mol Al(NO3)3 = 0.003 × 3 = 0.009 mol. Moles NaOH in excess = 0.015 - 0.009 = 0.006 mol. Volume of 0.15 M NaOH containing 0.006 mol = (0.006 mol) / (0.15 mol/dm³) = 0.04 dm³ = 40 cm³. Therefore, NaOH is in excess by 40 cm³.",
    "hint": "Calculate required moles, subtract from available, convert back to volume.",
    "timeLimit": 90,
    "year": 1983,
    "tags": [
      "chemistry",
      "stoichiometry",
      "excess reagent",
      "calculation",
      "jamb"
    ],
    "requiresCalculator": true,
    "calculatorType": "basic",
    "formula": "Al(NO3)3 + 3NaOH -> Al(OH)3 + 3NaNO3",
    "constants": {},
    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  }

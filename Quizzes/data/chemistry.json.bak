  },
  {
    "id": "CHEM-JAMB-0035",
    "question": "Increasing the pressure of a gas",
    "options": [
      "lowers the average kinetic energy of the molecules",
      "decreases the density of the gas",
      "decreases the temperature of the gas",
      "increases the density of the gas",
      "increases the volume of the gas"
    ],
    "answer": 3,
    "exam": [
      "JAMB"
    ],
    "level": "easy",
    "topic": "Acids, Bases & Salts",
    "marks": 1,
    "explanation": "According to Boyle's law, at constant temperature, pressure is inversely proportional to volume. Increasing pressure decreases volume. Density = mass/volume. Since mass remains constant and volume decreases, density increases. Average kinetic energy depends on temperature, not pressure.",
    "hint": "Density = mass/volume; volume decreases when pressure increases.",
    "timeLimit": 30,
    "year": 1983,
    "tags": [
      "chemistry",
      "gas laws",
      "boyle",
      "density",
      "jamb"
    ],
    "requiresCalculator": false,
    "calculatorType": "none",
    "formula": "",

  },
  {
    "id": "CHEM-JAMB-0028",
    "question": "Which of these metals, Mg, Fe, Pb, and Cu will dissolve in dilute HCl?",
    "options": [
      "All the metals",
      "Mg, Fe, and Cu",
      "Mg, Fe, and Pb",
      "Mg and Fe only",
      "Mg only"
    ],
    "answer": 3,
    "exam": [
      "JAMB"
    ],
    "level": "easy",
    "topic": "Organic Chemistry",
    "marks": 1,
    "explanation": "Metals above hydrogen in the reactivity series displace hydrogen from dilute acids. Magnesium and iron are above hydrogen and react with dilute HCl to produce hydrogen gas and their chlorides. Lead is below hydrogen and does not react with dilute HCl due to formation of insoluble PbCl₂ coating. Copper is below hydrogen and does not react with dilute HCl. Therefore, only Mg and Fe dissolve.",
    "hint": "Metals above H in reactivity series react with dilute acids.",
    "timeLimit": 30,
    "year": 1983,
    "tags": [
      "chemistry",
      "reactivity series",
      "acids",
      "jamb"
    ],
    "requiresCalculator": false,
    "calculatorType": "none",

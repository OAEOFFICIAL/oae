    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  },
  {
    "id": "CHEM-JAMB-0036",
    "question": "2.5 g of a hydrated barium salt gave on heating, 2.13 g of the anhydrous salt. Given that the relative molecular mass of the anhydrous salt is 208, the number of molecules of water of crystallization of the barium salt is",
    "options": [
      "10",
      "7",
      "5",
      "2",
      "1"
    ],
    "answer": 3,
    "exam": [
      "JAMB"
    ],
    "level": "medium",
    "topic": "Acids, Bases & Salts",
    "marks": 2,
    "explanation": "Mass of water lost = 2.50g - 2.13g = 0.37g. Molar mass H2O = 18 g/mol. Moles H2O lost = 0.37/18 = 0.02056 mol. Moles anhydrous salt = 2.13/208 = 0.01024 mol. Ratio = 0.02056/0.01024 ≈ 2.01 ≈ 2. Therefore, the hydrated salt contains 2 molecules of water of crystallization (dihydrate).",
    "hint": "Find moles of water lost and moles of anhydrous salt, then ratio.",
    "timeLimit": 60,
    "year": 1983,
    "tags": [
      "chemistry",
      "hydrates",
      "stoichiometry",
      "calculation",
      "jamb"
    ],
    "requiresCalculator": true,
    "calculatorType": "basic",
    "formula": "n = m/M",
    "constants": {
      "H2O": 18,
      "anhydrous salt": 208
    },
    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  },
  {
    "id": "CHEM-JAMB-0037",
    "question": "3.06 g of a sample of potassium trioxochlorate(V) (KClO3) was required to make a saturated solution with 10 cm³ of water at 25°C. The solubility of the salt at 25°C is [K=39, Cl=35.5, O=16]",
    "options": [
      "5.0 mol/dm³",
      "3.0 mol/dm³",
      "2.5 mol/dm³",
      "1.0 mol/dm³",
      "0.5 mol/dm³"
    ],
    "answer": 2,
    "exam": [
      "JAMB"
    ],
    "level": "medium",
    "topic": "Acids, Bases & Salts",
    "marks": 2,
    "explanation": "Molar mass KClO3 = 39 + 35.5 + (16×3) = 39 + 35.5 + 48 = 122.5 g/mol. Moles KClO3 = 3.06 g / 122.5 g/mol = 0.025 mol. Volume of water = 10 cm³ = 0.010 dm³. Solubility = moles/volume = 0.025 mol / 0.010 dm³ = 2.5 mol/dm³.",
    "hint": "Solubility in mol/dm³ = moles of solute / volume of solvent (dm³).",
    "timeLimit": 60,
    "year": 1983,
    "tags": [
      "chemistry",
      "solubility",
      "stoichiometry",
      "calculation",
      "jamb"
    ],
    "requiresCalculator": true,
    "calculatorType": "basic",
    "formula": "Solubility = n/V",
    "constants": {
      "K": 39,
      "Cl": 35.5,
      "O": 16
    },
    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  },
  {

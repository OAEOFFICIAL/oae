  {
    "id": "CHEM-JAMB-0011",
    "question": "A mixture of common salt, ammonium chloride and barium sulphate can best be separated by",
    "options": [
      "addition of water followed by filtration then sublimation",
      "addition of water followed by sublimation then filtration",
      "sublimation followed by addition of water then filtration",
      "fractional distillation",
      "fractional crystallization"
    ],
    "answer": 2,
    "exam": [
      "JAMB"
    ],
    "level": "medium",
    "topic": "Practical Chemistry: Separation Techniques",
    "marks": 2,
    "explanation": "Ammonium chloride sublimes on heating (changes directly from solid to gas), leaving behind common salt (NaCl) and barium sulphate (BaSO4). After sublimation, add water to dissolve NaCl (soluble), while BaSO4 remains insoluble. Filtration separates BaSO4 as residue. Evaporating the filtrate recovers NaCl. Sublimation first is essential to prevent NH4Cl from dissolving in water along with NaCl.",
    "hint": "NH4Cl sublimes; NaCl dissolves; BaSO4 is insoluble.",
    "timeLimit": 45,
    "year": 1983,
    "tags": [
      "chemistry",
      "separation techniques",
      "sublimation",
      "practical chemistry",
      "jamb"
    ],
    "requiresCalculator": false,
    "calculatorType": "none",

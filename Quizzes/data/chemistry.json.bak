  {
    "id": "CHEM-JAMB-0030",
    "question": "What volume of 0.50 M H2SO4 will exactly neutralize 20cm³ of 0.1 M NaOH solution?",
    "options": [
      "2.0 cm³",
      "5.0 cm³",
      "6.8 cm³",
      "8.3 cm³",
      "10.4 cm³"
    ],
    "answer": 0,
    "exam": [
      "JAMB"
    ],
    "level": "medium",
    "topic": "Acids, Bases & Salts",
    "marks": 2,
    "explanation": "Reaction: H2SO4 + 2NaOH → Na2SO4 + 2H2O. Mole ratio H2SO4 : NaOH = 1:2. Moles NaOH = (0.1 mol/dm³) × (20/1000) dm³ = 0.002 mol. Moles H2SO4 needed = 0.002 / 2 = 0.001 mol. Volume H2SO4 = moles / concentration = 0.001 mol / 0.50 mol/dm³ = 0.002 dm³ = 2.0 cm³.",
    "hint": "Remember H2SO4 has 2 H⁺ ions.",
    "timeLimit": 60,
    "year": 1983,
    "tags": [
      "chemistry",
      "titration",
      "acid-base",
      "stoichiometry",
      "jamb"
    ],
    "requiresCalculator": true,
    "calculatorType": "basic",
    "formula": "C1V1/n1 = C2V2/n2",
    "constants": {},
    "createdBy": "OAE Admin",
    "lastUpdated": "2026-04-05"
  },
  {
    "id": "CHEM-JAMB-0031",
    "question": "Which of the following pairs of gases will NOT react further with oxygen at a temperature between 30°C and 400°C?",
    "options": [
      "SO2 and NH3",
      "CO2 and H2",
      "NO2 and SO3",
      "SO3 and NO",
      "CO and H2"
    ],
    "answer": 2,
    "exam": [
      "JAMB"
    ],
    "level": "hard",
    "topic": "Organic Chemistry",
    "marks": 2,
    "explanation": "NO2 and SO3 are already fully oxidized products. NO2 is an oxide of nitrogen in a high oxidation state, SO3 is sulfur trioxide (sulfur in +6 oxidation state). Neither will react further with oxygen under normal conditions. CO and H2 are reducing agents and react with O2; SO2 reacts to form SO3; NH3 burns in O2; NO reacts with O2 to form NO2.",
    "hint": "Look for gases already in their highest oxidation states.",
    "timeLimit": 60,

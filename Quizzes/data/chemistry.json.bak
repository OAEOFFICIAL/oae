  {
    "id": "CHEM-JAMB-0039",
    "question": "A gas that can behave as reducing agent towards chlorine and as an oxidizing agent towards hydrogen sulphide is",
    "options": [
      "O2",
      "NO",
      "SO2",
      "NH3",
      "CO2"

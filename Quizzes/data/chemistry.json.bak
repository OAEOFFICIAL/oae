  {
    "id": "CHEM-JAMB-0023",
    "question": "Which of the following happens during the electrolysis of molten sodium chloride?",
    "options": [
      "Sodium ion loses an electron",
      "Chlorine atom gains an electron",
      "Chloride ion gains an electron",
      "Sodium ion is oxidized",
      "Chloride ion is oxidized"
    ],
    "answer": 4,
    "exam": [
      "JAMB"
    ],
    "level": "easy",
    "topic": "Acids, Bases & Salts",
    "marks": 1,
    "explanation": "During electrolysis of molten NaCl, Na⁺ ions migrate to the cathode and are reduced (gain electrons) to form sodium metal: Na⁺ + e⁻ → Na. Cl⁻ ions migrate to the anode and are oxidized (lose electrons) to form chlorine gas: 2Cl⁻ → Cl₂ + 2e⁻. Therefore, chloride ion is oxidized.",
    "hint": "Anode attracts anions (Cl⁻) which lose electrons.",
    "timeLimit": 30,
    "year": 1983,
    "tags": [
